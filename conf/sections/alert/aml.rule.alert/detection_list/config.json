{
  "code": "aml.rule.alert.detection_list",
  "name": "AML TM Retail Alert Detection List",
  "version": "1.0.0",
  "permissions": ["data.alert"],
  "apiCalls": [
    {
      "name": "alert_detail",
      "endpoint": "/api/data/alert/detail",
      "params": {"alert_id": "{{entity_id}}"},
      "required": true,
      "variable_name": "alert"
    }
  ],
  "rootComponent": {
    "id": "table",
    "type" : "data-table",
    "dataMode": "reference",
    "props": {
      "columns": [
        {"id": "name", "label": "Detection Name", "accessor": "name"},               
        {"id": "score", "label": "Score", "accessor": "score"},
        {"id": "time_frame", "label": "Time Frame", "accessor": "time_frame"}
      ],
      "data": "{{alert.detections}}",
      "pagination": true,
      "pageSize" : 5    
    }
  }
}
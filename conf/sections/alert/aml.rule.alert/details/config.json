{
  "code": "aml.rule.alert.details",
  "name": "AML TM Retail Alert Detail",
  "version": "1.0.0",
  "i18nNamespace": "ComponentSection.Sections.AmlRuleAlert.Details",
  "permissions": ["data.alert"],
  "apiCalls": [
    {
      "name": "alert_detail",
      "endpoint": "/api/data/alert/detail",
      "params": {"alert_id": "{{entity_id}}"},
      "required": true,
      "variable_name": "alert"
    }
  ],
  "rootComponent": {
    "id": "root",
    "type": "tabs",
    "props": {
      "tabs": [
        { "id": "det-tab1", "label": "Detections", "i18nKey": "tabDetections" }
      ]
    },
    "children": [
      {
        "id": "detections-table",
        "type": "data-table",
        "dataMode": "reference",
        "props": {
          "columns": [
            {"id": "name", "label": "Detection Name", "accessor": "name", "i18nKey": "colName"},
            {"id": "info", "label": "Info", "accessor": "info", "i18nKey": "colInfo"},                
            {"id": "score", "label": "Score", "accessor": "score", "i18nKey": "colScore"},
            {"id": "time_frame", "label": "Time Frame", "accessor": "time_frame", "i18nKey": "colTimeFrame"}
          ],
          "data": "{{alert.detections}}",
          "pagination": true
        }
      }
    ]
  }
}